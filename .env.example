# Shopify Storefront API credentials.
#
# These are NOT required today — the app runs entirely on the mock data layer
# (see lib/shopify/). Fill these in when you are ready to connect the live
# store, then implement the real client in lib/shopify/storefront-client.ts and
# flip the export in lib/shopify/index.ts.

# your-store.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Storefront API public access token (from a Shopify custom app / Headless channel)
SHOPIFY_STOREFRONT_API_TOKEN=

# Storefront API version, e.g. 2025-01
SHOPIFY_STOREFRONT_API_VERSION=2025-01
