# -----------------------------------------------------------------------------
# Data source flag
# -----------------------------------------------------------------------------
# true  → run on the built-in mock data layer (no Shopify needed). DEFAULT.
# false → use the live Storefront API client (requires the vars below +
#         an implemented lib/shopify/live/client.ts).
NEXT_PUBLIC_USE_MOCK=true

# -----------------------------------------------------------------------------
# Shopify Storefront API (only needed when NEXT_PUBLIC_USE_MOCK=false)
# -----------------------------------------------------------------------------
# your-store.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Storefront API public access token (Headless channel or a custom app)
SHOPIFY_STOREFRONT_API_TOKEN=
# API version is locked to 2026-07 for this build.
SHOPIFY_STOREFRONT_API_VERSION=2026-07

# -----------------------------------------------------------------------------
# Analytics (loaded only after cookie consent). IDs are placeholders until set.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
