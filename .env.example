# -----------------------------------------------------------------------------
# Site URL (used by robots.txt, sitemap.xml, llms.txt, Open Graph)
# -----------------------------------------------------------------------------
# The real production origin, no trailing slash, e.g. https://fyndladan.se.
# Falls back to the Vercel preview URL, then localhost, if unset.
NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------------------------------------
# Data source flag
# -----------------------------------------------------------------------------
# true  → run on the built-in mock data layer (no Shopify needed). DEFAULT.
# false → use the live Storefront API client (requires the vars below +
#         an implemented lib/shopify/live/client.ts).
NEXT_PUBLIC_USE_MOCK=true

# -----------------------------------------------------------------------------
# Shopify Storefront API (only needed when NEXT_PUBLIC_USE_MOCK=false)
# -----------------------------------------------------------------------------
# your-store.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Storefront API public access token (Headless channel or a custom app)
SHOPIFY_STOREFRONT_API_TOKEN=
# API version is locked to 2026-07 for this build.
SHOPIFY_STOREFRONT_API_VERSION=2026-07

# -----------------------------------------------------------------------------
# Analytics (loaded only after cookie consent). IDs are placeholders until set.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# -----------------------------------------------------------------------------
# Lead capture (/api/lead). Each sink below is independently optional: leave
# a block blank to skip it, the endpoint still succeeds for the customer.
# -----------------------------------------------------------------------------
# Shopify Admin API (separate from the Storefront token above). Create a
# custom app in Shopify admin with the write_customers scope.
SHOPIFY_ADMIN_API_TOKEN=

# Google Sheets: create a service account in Google Cloud, enable the Sheets
# API, then share the target spreadsheet with the service account's email
# (Editor access).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Leads
